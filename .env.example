# Google Gemini (https://aistudio.google.com/apikey)
GOOGLE_API_KEY=
# Free tier: use gemini-2.5-flash-lite (gemini-2.0-flash often has limit 0)
CHAT_MODEL=gemini-2.5-flash-lite

# Postgres (host machine; Docker overrides in compose)
DATABASE_URL=postgresql+asyncpg://rag:rag@localhost:5432/rag

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=document_chunks_gemini_v2

# JWT
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# App
UPLOAD_DIR=/data/uploads
MAX_UPLOAD_MB=25
CORS_ORIGINS=http://localhost:3000
